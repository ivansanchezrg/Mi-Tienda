<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- Las lineas comentadas son la originales -->
    <!-- <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style> -->

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Fondo del splash — mismo gris de la app para transición suave -->
        <item name="windowSplashScreenBackground">#f4f5f8</item>
        <!--
          ic_launcher (no ic_launcher_foreground) como ícono del splash.
          El foreground PNG tiene transparencia en el área de safe zone del
          adaptive icon — cuando Android 12+ lo escala y anima (zoom-in),
          el ícono puede no verse si el contenido real cae fuera del círculo
          de recorte. El ic_launcher.png ya tiene el ícono completo con fondo
          azul incorporado, garantizando visibilidad siempre.
        -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Le dice a Android que el ícono tiene su propio fondo — sin esto,
             Android 12+ dibuja un círculo blanco detrás del PNG en algunos OEMs. -->
        <item name="windowSplashScreenIconBackgroundColor">#f4f5f8</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>