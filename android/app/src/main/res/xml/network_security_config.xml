<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Política de seguridad de red — Mi Tienda
        - Bloquea cleartext HTTP por defecto.
        - Solo permite HTTPS a Supabase y dominios necesarios.
        - Confía en CAs del sistema; no se hace cert pinning (Supabase rota certificados).
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Dominios permitidos vía HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.in</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
